{
  "functions": {
    "api/ai-analysis.ts": { "maxDuration": 300 },
    "api/auth/connect.ts": { "maxDuration": 60 },
    "api/points.ts": { "maxDuration": 60 },
    "api/tenki-html.ts": { "maxDuration": 30 }
  },
  "rewrites": [
    {
      "source": "/aviation-weather/:path*",
      "destination": "https://aviationweather.gov/:path*"
    },
    {
      "source": "/polymarket-gamma/:path*",
      "destination": "https://gamma-api.polymarket.com/:path*"
    },
    {
      "source": "/polymarket-clob/:path*",
      "destination": "https://clob.polymarket.com/:path*"
    },
    {
      "source": "/hko-wxinfo/:path*",
      "destination": "https://www.weather.gov.hk/wxinfo/:path*"
    },
    {
      "source": "/moji-fetch/:path*",
      "destination": "https://tianqi.moji.com/:path*"
    },
    {
      "source": "/cma-fetch/:path*",
      "destination": "https://weather.cma.cn/:path*"
    },
    {
      "source": "/hbt-fetch/:path*",
      "destination": "http://wechat.hbt7.com/:path*"
    },
    {
      "source": "/nws-mapclick/:path*",
      "destination": "https://forecast.weather.gov/:path*"
    },
    {
      "source": "/tenki-fetch/:path*",
      "destination": "https://tenki.jp/:path*"
    },
    {
      "source": "/kma-fetch/:path*",
      "destination": "https://www.weather.go.kr/:path*"
    },
    {
      "source": "/tools",
      "destination": "/index.html"
    },
    {
      "source": "/tools/:path*",
      "destination": "/index.html"
    }
  ]
}