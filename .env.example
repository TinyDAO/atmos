# Optional: Add API keys for multi-source temperature comparison
# VITE_OPENWEATHER_API_KEY=your_openweathermap_key
# VITE_WEATHERAPI_KEY=your_weatherapi_key
# VITE_WUNDERGROUND_API_KEY=your_weather_company_key

# AI Analysis API
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# Upstash Redis (optional cache)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# API protection: comma-separated allowed origins (empty = allow all)
# ALLOWED_ORIGINS=https://your-site.com,http://localhost:3000

# RainbowKit / WalletConnect (https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id

# Neon (Vercel integration or manual)
DATABASE_URL=postgresql://...
